{
  "manifest_version": 3,
  "name": "Youtube Kid Theme",
  "version": "1.0",
  "description": "Yt kid theme",
  "icons": {
    "16": "img/justdog_16.webp",
    "32": "img/justdog_16.webp",
    "48": "img/justdog_16.webp",
    "128": "img/justdog_16.webp"
  },
  "permissions": [
    "webRequest", "tabs", "activeTab", "scripting", "webNavigation", "storage"
  ],
  "host_permissions": [
    "*://www.youtubekids.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtubekids.com/*"],
      "css": ["css/style.css"],
      "js": [
        "scripts/touch-emulator.js",
        "scripts/three.min.js",
        "scripts/language.js",
        "scripts/search-data.js",
        "scripts/helper.js",
        "scripts/events.js",
        "scripts/content.js"

      ]
    }
  ],
  "web_accessible_resources": [{
    "matches": ["<all_urls>"],
    "resources": ["img/*"]
  }],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  }
}
